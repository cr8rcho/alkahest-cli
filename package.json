{
  "name": "alkahest",
  "version": "0.1.0",
  "description": "코드에서 제품을 역복원하는 화면-그래프 CLI (React/Next 정적 분석 → 제품 지도)",
  "type": "module",
  "bin": {
    "alkahest": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "react",
    "nextjs",
    "product-map",
    "screen-graph",
    "static-analysis",
    "prd",
    "mcp",
    "ast"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cr8rcho/alkahest.git"
  },
  "homepage": "https://github.com/cr8rcho/alkahest#readme",
  "bugs": {
    "url": "https://github.com/cr8rcho/alkahest/issues"
  },
  "author": "cr8rcho",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "ts-morph": "^28.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
